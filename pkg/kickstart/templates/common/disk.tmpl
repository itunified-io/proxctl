{{- define "disk" -}}
# Disk partitioning — LVM on the first disk; additional disks left for post-install.
zerombr
clearpart --all --initlabel
bootloader --location=mbr --timeout=5
part /boot --fstype=xfs --size=1024 --asprimary
part /boot/efi --fstype=vfat --size=512 --asprimary
part pv.01 --size=1 --grow
volgroup vg_system pv.01
logvol swap --name=lv_swap --vgname=vg_system --size=4096
logvol / --fstype=xfs --name=lv_root --vgname=vg_system --size=1 --grow
{{- end -}}
