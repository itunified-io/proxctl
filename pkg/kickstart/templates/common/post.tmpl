{{- define "post_common" -}}
%post --erroronfail --log=/var/log/ks-post.log
echo "proxclt post-install start: $(date)"

# Chrony servers
{{- if .Kickstart.ChronyServers }}
{
  echo "# proxclt chrony servers"
{{- range $srv := .Kickstart.ChronyServers }}
  echo "server {{ $srv }} iburst"
{{- end }}
} >> /etc/chrony.conf
systemctl enable chronyd || true
{{- end }}

# IPv6 toggle
{{- if not .Kickstart.IPv6Enabled }}
echo "net.ipv6.conf.all.disable_ipv6 = 1" >> /etc/sysctl.d/99-disable-ipv6.conf
echo "net.ipv6.conf.default.disable_ipv6 = 1" >> /etc/sysctl.d/99-disable-ipv6.conf
{{- end }}

# Sudoers
{{- if and .Kickstart.Sudo .Kickstart.Sudo.WheelNopasswd }}
echo "%wheel ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/90-wheel-nopasswd
chmod 440 /etc/sudoers.d/90-wheel-nopasswd
{{- end }}

# /etc/hosts cluster entries
{{- if .Cluster }}
{{- range $h := .Cluster.HostsEntries }}
echo "{{ $h.IP }} {{ join " " $h.Names }}" >> /etc/hosts
{{- end }}
{{- end }}

# System update
{{- if .Kickstart.UpdateSystem }}
dnf -y update || true
{{- end }}

# Post packages
{{- if and .Kickstart.Packages .Kickstart.Packages.Post }}
dnf -y install {{ join " " .Kickstart.Packages.Post }} || true
{{- end }}

touch /var/log/install-success
echo "Installation completed successfully at $(date)" >> /var/log/install-success
%end
{{- end -}}
